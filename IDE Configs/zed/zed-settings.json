{
  "edit_predictions": {
    "provider": "copilot",
  },
  "context_servers": {},
  "icon_theme": "Material Icon Theme",
  "agent": {
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6",
    },
    "model_parameters": [],
  },
  "terminal": {
    "font_size": 14.0,
  },
  "minimap": {
    "thumb": "always",
  },
  "scrollbar": {
    "axes": {
      "horizontal": false,
      "vertical": false,
    },
  },
  "cursor_blink": true,
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 18.0,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Xcode High Contrast Darker",
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "auto_install_extensions": {
    "html": true,
    "comment": true,
    "codebook": true,
    "dockerfile": true,
    "xcode-themes": true,
    "docker-compose": true,
    "react-snippets-es7": true,
    "material-icon-theme": true,
  },
}
